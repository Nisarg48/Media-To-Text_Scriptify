# ── Backend ───────────────────────────────
PORT=5000
MONGODBUSERNAME=
MONGODBPASSWORD=
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/scriptify_dev?appName=Scriptify-Cluster&w=majority
JWT_SECRET=
# For local dev (no Docker): amqp://127.0.0.1. Docker compose overrides to amqp://rabbitmq:5672.
RABBITMQ_URL=amqp://127.0.0.1
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=scriptify-dev
RABBITMQ_QUEUE=scriptify-transcribe-queue
STORAGE_ENDPOINT=http://localhost:9000
# URL the browser uses for upload/playback (e.g. MinIO). With Docker, use http://localhost:9000.
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=scriptify-dev

# ── Stripe (billing) — test keys in Test mode; required for checkout/portal/webhooks ──
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID_PRO=
STRIPE_WEBHOOK_SECRET=
# Base URL users return to after Checkout (browser origin often used instead). Docker: http://localhost
FRONTEND_URL=http://localhost

# ── Frontend (build-time) ─────────────────
VITE_API_BASE_URL=http://localhost:5000/api

# ── AI Worker ─────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/scriptify_dev?appName=Scriptify-Cluster&w=majority
MONGODB_DATABASE_NAME=scriptify_dev
SUPPORTED_EXTENSIONS=.mp3,.wav,.m4a,.flac,.ogg,.mp4,.mkv,.avi,.mov,.webm
GEMINI_API_KEY=
GEMINI_SUMMARY_MODEL=gemini-1.5-flash
# Whisper model size: tiny, base, small, medium (recommended), large-v3
# Use medium for better accuracy. large-v3 is heavier and may not fit smaller GPUs.
WHISPER_MODEL=small

# ── Monitoring ────────────────────────────
# Grafana admin password. Default: admin. Change for production.
GRAFANA_PASSWORD=admin

