{
  "annotations": { "list": [] },
  "description": "HTTP traffic and response health for the Scriptify backend API. Use this to track request volume, latency trends, and error rates per endpoint. Alert thresholds are set for 5xx error rate and p95 latency.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Request Volume",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of HTTP requests per second, broken down by HTTP method and route. Spikes indicate load increases; drops may indicate availability issues.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(scriptify_http_requests_total[2m])) by (method, route)",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Route (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Proportion of requests that returned a 4xx or 5xx status code. Values above 5% trigger an alert.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(sum(rate(scriptify_http_requests_total{status=~\"[45]..\"}[5m])) or vector(0)) / sum(rate(scriptify_http_requests_total[5m]))",
          "legendFormat": "Error rate",
          "refId": "A"
        }
      ],
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "alert": {
        "name": "High HTTP Error Rate",
        "message": "HTTP 5xx error rate has exceeded 5% for 2 minutes. Investigate backend logs immediately.",
        "conditions": [
          {
            "type": "query",
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "last", "params": [] },
            "evaluator": { "type": "gt", "params": [0.05] }
          }
        ],
        "executionErrorState": "alerting",
        "for": "2m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [{ "uid": "email-receiver" }]
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 11,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Response time percentiles across all endpoints. p50 = median, p95 = 95th percentile, p99 = 99th percentile. p95 > 2000ms triggers an alert.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 6 },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(scriptify_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(scriptify_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(scriptify_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Response Latency — p50 / p95 / p99",
      "type": "timeseries",
      "alert": {
        "name": "Slow API — p95 Latency > 2s",
        "message": "API p95 response time has been above 2000ms for 5 minutes. Possible DB slowness, heavy load, or blocking operation.",
        "conditions": [
          {
            "type": "query",
            "query": { "params": ["B", "5m", "now"] },
            "reducer": { "type": "last", "params": [] },
            "evaluator": { "type": "gt", "params": [2000] }
          }
        ],
        "executionErrorState": "alerting",
        "for": "5m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [{ "uid": "email-receiver" }]
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Request rate split by HTTP status class — 2xx (success), 4xx (client error), 5xx (server error). Useful for at-a-glance traffic quality assessment.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(scriptify_http_requests_total{status=~\"2..\"}[2m]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(scriptify_http_requests_total{status=~\"4..\"}[2m]))",
          "legendFormat": "4xx",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(scriptify_http_requests_total{status=~\"5..\"}[2m]))",
          "legendFormat": "5xx",
          "refId": "C"
        }
      ],
      "title": "Requests by Status Class",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 12,
      "title": "Top Routes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total number of HTTP requests per route over the selected time range. Identifies the most-used endpoints.",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sort_desc(sum by (route, method) (increase(scriptify_http_requests_total[1h])))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "title": "Top Routes — Request Count (last 1h)",
      "type": "bargauge"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["scriptify", "api", "http"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Scriptify: API Health",
  "uid": "scriptify-api-http",
  "version": 1
}
