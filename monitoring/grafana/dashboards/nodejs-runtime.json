{
  "annotations": { "list": [] },
  "description": "Internal health of the Node.js backend process. Heap memory, CPU load, event loop lag, and active handle counts help diagnose memory leaks, CPU spikes, and I/O bottlenecks. Alert is set for heap usage exceeding 85%.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 20,
      "title": "Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "V8 heap memory used vs the total heap size allocated. A steadily growing 'used' line without a corresponding rise in 'total' is a healthy GC pattern. If 'used' approaches 'total' and keeps rising, it indicates a memory leak. Alert fires when used > 85% of total.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scriptify_nodejs_heap_size_used_bytes",
          "legendFormat": "Heap used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scriptify_nodejs_heap_size_total_bytes",
          "legendFormat": "Heap total",
          "refId": "B"
        }
      ],
      "title": "V8 Heap Memory — Used vs Total",
      "type": "timeseries",
      "alert": {
        "name": "High Heap Memory Usage",
        "message": "Node.js heap usage has exceeded 85% for 3 minutes. Risk of out-of-memory crash. Check for memory leaks or increase container memory limit.",
        "conditions": [
          {
            "type": "query",
            "query": { "params": ["A", "3m", "now"] },
            "reducer": { "type": "last", "params": [] },
            "evaluator": {
              "type": "gt",
              "params": [0]
            }
          }
        ],
        "executionErrorState": "alerting",
        "for": "3m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [{ "uid": "email-receiver" }]
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Heap usage as a percentage of the total heap. Values above 85% are highlighted in red.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.70 },
              { "color": "red", "value": 0.85 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scriptify_nodejs_heap_size_used_bytes / scriptify_nodejs_heap_size_total_bytes",
          "legendFormat": "Heap %",
          "refId": "A"
        }
      ],
      "title": "Heap Usage %",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total RSS (Resident Set Size) — all memory occupied by the Node.js process including code, stack, and heap.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scriptify_process_resident_memory_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "title": "Process RSS",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 21,
      "title": "CPU & Event Loop",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "CPU time consumed by the Node.js process as a fraction of total CPU capacity (0–1 = 0–100%). Sustained values above 0.8 indicate the process is CPU-bound and may need optimization or horizontal scaling.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(scriptify_process_cpu_seconds_total[1m])",
          "legendFormat": "CPU usage",
          "refId": "A"
        }
      ],
      "title": "Node.js CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Node.js event loop lag measures how long the event loop is blocked beyond its scheduled tick. Values above 100ms indicate synchronous blocking — usually heavy computation, slow DB queries, or large JSON parsing on the main thread.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scriptify_nodejs_eventloop_lag_seconds * 1000",
          "legendFormat": "Event loop lag",
          "refId": "A"
        }
      ],
      "title": "Event Loop Lag (ms)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 22,
      "title": "Active Handles & Process Info",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Active handles are open TCP connections, timers, file descriptors etc. Active requests are in-flight async operations. A growing handle count that never drops can indicate connection leaks.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scriptify_nodejs_active_handles_total",
          "legendFormat": "Active handles",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scriptify_nodejs_active_requests_total",
          "legendFormat": "Active requests",
          "refId": "B"
        }
      ],
      "title": "Active Handles & Requests",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "How long the Node.js process has been running without a restart. A restart resets this counter. Useful for detecting unexpected container restarts.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 19 },
      "id": 7,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scriptify_process_start_time_seconds",
          "legendFormat": "Start time (epoch)",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Process Uptime",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Node.js runtime version currently running in the backend container.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 19 },
      "id": 8,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scriptify_nodejs_version_info",
          "legendFormat": "Node {{version}}",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Node.js Version",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["scriptify", "nodejs", "runtime"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Scriptify: Node.js Runtime",
  "uid": "scriptify-nodejs",
  "version": 1
}
