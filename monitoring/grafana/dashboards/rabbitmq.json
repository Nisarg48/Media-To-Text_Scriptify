{
  "annotations": { "list": [] },
  "description": "Message queue health for the AI transcription pipeline. Monitors queue depth, message throughput, and consumer presence. A growing queue depth means the worker is falling behind or is down. Alert fires when ready messages exceed 20.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 30,
      "title": "Queue Snapshot",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Messages waiting in the queue that have not yet been delivered to a consumer. If this value grows steadily it means the AI worker is not keeping up with uploads — check if the worker container is running and healthy.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rabbitmq_queue_messages_ready)",
          "legendFormat": "Ready",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Messages Ready (Queue Depth)",
      "type": "stat",
      "alert": {
        "name": "Transcription Queue Backed Up",
        "message": "More than 20 jobs are waiting in the transcription queue. The AI worker may be down or overloaded. Check scriptify-worker container logs.",
        "conditions": [
          {
            "type": "query",
            "query": { "params": ["A", "3m", "now"] },
            "reducer": { "type": "last", "params": [] },
            "evaluator": { "type": "gt", "params": [20] }
          }
        ],
        "executionErrorState": "alerting",
        "for": "3m",
        "frequency": "1m",
        "noDataState": "no_data",
        "notifications": [{ "uid": "email-receiver" }]
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Messages that have been delivered to the worker but not yet acknowledged. A non-zero value here is expected while a job is processing. A persistently high value indicates the worker is consuming but not completing/acknowledging jobs.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rabbitmq_queue_messages_unacked)",
          "legendFormat": "Unacked",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Messages Unacknowledged",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of active consumers attached to the transcription queue. Should be 1 (the AI worker). Zero means no worker is running — uploads will queue up but not be processed.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rabbitmq_queue_consumers)",
          "legendFormat": "Consumers",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Queue Consumers (Worker Count)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total number of open connections to RabbitMQ. Normally 2–3: backend (publisher) + worker (consumer) + management plugin.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_connections",
          "legendFormat": "Connections",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Total Connections",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 31,
      "title": "Throughput Over Time",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Queue depth over time. A flat line near zero is healthy. A rising line means jobs are arriving faster than they are processed.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 12 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rabbitmq_queue_messages_ready)",
          "legendFormat": "Ready",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rabbitmq_queue_messages_unacked)",
          "legendFormat": "Unacked",
          "refId": "B"
        }
      ],
      "title": "Queue Depth Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Rate at which messages are published into and delivered from the queue. Published rate = upload rate; delivered rate = worker processing rate. A gap between published and delivered means jobs are accumulating.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(rabbitmq_channel_messages_published_total[2m]))",
          "legendFormat": "Published/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(rabbitmq_channel_messages_delivered_total[2m]))",
          "legendFormat": "Delivered/s",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(rabbitmq_channel_messages_acked_total[2m]))",
          "legendFormat": "Acked/s",
          "refId": "C"
        }
      ],
      "title": "Message Throughput (publish / deliver / ack)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 32,
      "title": "RabbitMQ Node Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Memory used by the RabbitMQ broker process. If this approaches the configured memory watermark, RabbitMQ will start blocking publishers to prevent running out of memory.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_process_resident_memory_bytes",
          "legendFormat": "RabbitMQ RSS",
          "refId": "A"
        }
      ],
      "title": "RabbitMQ Process Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of open file descriptors used by the RabbitMQ broker. Each connection and channel consumes a file descriptor. If this approaches the system limit, new connections will be refused.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_process_open_fds",
          "legendFormat": "Open FDs",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_process_max_fds",
          "legendFormat": "FD limit",
          "refId": "B"
        }
      ],
      "title": "Open File Descriptors vs Limit",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["scriptify", "rabbitmq", "queue"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Scriptify: Job Queue (RabbitMQ)",
  "uid": "scriptify-rabbitmq",
  "version": 1
}
